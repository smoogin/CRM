generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Company {
  id        String    @id @default(cuid())
  name      String
  industry  String?
  website   String?
  phone     String?
  address   String?
  city      String?
  state     String?
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  contacts  Contact[]
  projects  Project[]
}

model Contact {
  id         String    @id @default(cuid())
  firstName  String
  lastName   String
  title      String?
  email      String?
  phone      String?
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  companyId  String?
  company    Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)

  projects   Project[]
}

model Vendor {
  id           String          @id @default(cuid())
  name         String
  category     String?         // e.g. Corrugated, Films, Labels, Foam
  contactName  String?
  email        String?
  phone        String?
  website      String?
  leadTimeDays Int?
  rating       Int?            // 1-5
  notes        String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  projects     ProjectVendor[]
}

model Stage {
  id        String    @id @default(cuid())
  name      String
  color     String    @default("#64748b")
  category  String    @default("OPEN") // OPEN, WON, LOST — drives dashboard rollups
  position  Int       @default(0)
  createdAt DateTime  @default(now())

  projects  Project[]
}

model Project {
  id           String          @id @default(cuid())
  name         String
  description  String?
  priority     String          @default("MEDIUM") // LOW, MEDIUM, HIGH
  position     Int             @default(0)         // order within a stage
  quantity     Int?
  targetDate   DateTime?
  notes        String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  stageId      String
  stage        Stage           @relation(fields: [stageId], references: [id])

  companyId    String?
  company      Company?        @relation(fields: [companyId], references: [id], onDelete: SetNull)

  contactId    String?
  contact      Contact?        @relation(fields: [contactId], references: [id], onDelete: SetNull)

  estRevenue   Float?          // expected sell price total
  estCost      Float?          // expected cost total

  financials   FinancialEntry[]
  vendors      ProjectVendor[]
  attachments  Attachment[]
}

model Attachment {
  id           String   @id @default(cuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  filename     String   // stored filename on disk (server-generated)
  originalName String   // display name from the user's upload
  mimeType     String
  size         Int
  createdAt    DateTime @default(now())
}

model ProjectVendor {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  vendorId  String
  vendor    Vendor  @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  role      String? // what they supply for this project
  quotedCost Float?

  @@unique([projectId, vendorId])
}

model MarkupCalc {
  id        String   @id @default(cuid())
  label     String?
  quantity  Int
  unitCost  Float
  unitSell  Float
  markup    Float
  totalCost Float
  totalSell Float
  createdAt DateTime @default(now())
}

model Prospect {
  id                  String      @id @default(cuid())
  name                String
  address             String?
  lat                 Float?
  lng                 Float?
  county              String?
  status              String      @default("cold") // cold, warm, hot, customer, dormant
  vertical            String?     // firearms, automotive Tier 2-3, food & bev, medical, ag, e-commerce/3PL, other
  dealValueEstimate   Float?
  lastContactDate     DateTime?
  notes               String?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  visits              VisitLog[]
  inventory           InventoryItem[]
  expenses            Expense[]
}

model InventoryItem {
  id            String   @id @default(cuid())
  prospectId    String
  prospect      Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  filename      String   // stored file on disk (server-generated)
  mimeType      String
  size          Int
  packagingType String   // rigid box / folding carton / sleeve / clamshell / backer card / POP display / other
  notes         String?
  dateCaptured  DateTime @default(now())
  createdAt     DateTime @default(now())
}

model Expense {
  id         String    @id @default(cuid())
  prospectId String?
  prospect   Prospect? @relation(fields: [prospectId], references: [id], onDelete: SetNull)
  type       String    // gas / meal / gift / other
  amount     Float
  miles      Float?    // optional, for gas mileage calc
  date       DateTime  @default(now())
  notes      String?
  createdAt  DateTime  @default(now())
}

model VisitLog {
  id         String   @id @default(cuid())
  prospectId String
  prospect   Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  date       DateTime @default(now())
  type       String   // cold call, check-in, meeting, call, drop-off
  notes      String?
  xpAwarded  Int      @default(0)
  createdAt  DateTime @default(now())
}

model FinancialEntry {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type      String   // REVENUE or COST
  category  String?  // Materials, Freight, Tooling, Commission, etc.
  label     String
  amount    Float
  date      DateTime @default(now())
  createdAt DateTime @default(now())
}
